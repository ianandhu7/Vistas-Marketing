# ============================================================
# backend/.env.example — SAFE TO COMMIT (no real values)
# Copy this file to backend/.env and fill in your real values.
# ============================================================

# --- Database ---
DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/vlearning?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DATASOURCE_USERNAME=root
DATASOURCE_PASSWORD=your_mysql_password_here
HIBERNATE_DDL=update

# --- JWT ---
JWT_NAME=vlearning
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_EXPIRATION_INMS=86400000
JWT_MOB_EXPIRATION_INMS=86400000
JWT_REFRESH_INMS=2592000000
LOCK_DURATION=300

# --- Email (AWS SES) ---
SES_MAIL_USERNAME=your_ses_smtp_username
SES_MAIL_PASSWORD=your_ses_smtp_password

# --- Payment ---
WEBAPP_PAYMENT_URL=http://localhost:5173/payment-response
MERCHANT_ID=your_paytm_merchant_id
PAYTM_PAYMENT_URL=https://securegw-stage.paytm.in/order/process
PAYTM_PAYMENT_CALLBACK_URL=http://localhost:9090/api/payment/callback
PAYTM_INITIATE_TRANSACTION_URL=https://securegw-stage.paytm.in/theia/api/v1/initiateTransaction
PAYTM_ORDER_STATUS_URL=https://securegw-stage.paytm.in/v3/order/status
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=

# --- AWS ---
AWS_ACCESSKEY=your_aws_access_key_id
AWS_SECRETACCESS=your_aws_secret_access_key
S3_BUCKET=your-s3-bucket-name
DYNAMO_DB_REGION=ap-south-1

# --- App URLs ---
APP_ANGULAR_URL=http://localhost:5173
APP_SHARE_URL=http://localhost:5173
BE_DNS_URL=http://localhost:9090
MARKETING_FRONTEND_URL=http://localhost:5173

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the real FCM credentials JSON (use file: prefix for external path)
FCM_CREDENTIALS_PATH=file:secrets/fcm.json

# --- iOS In-App Purchase ---
IN_APP_PURCHASE_ISSUER_ID=your_issuer_id
IN_APP_PURCHASE_KEY_ID=your_key_id
IN_APP_PURCHASE_BUNDLE_ID=your_bundle_id
IN_APP_PURCHASE_ENVIRONMENT=sandbox
# Path to the real IAP key (use file: prefix for external path)
IOS_IAP_KEY_PATH=file:secrets/SubscriptionKey_GRXV39P637.p8

# --- Secrets / API Keys ---
VIDEOCIPHER_SECRET=your_videocipher_secret
SMS_APIKEY_ID=your_sms_api_key
SENDGRID_API_KEY=your_sendgrid_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_SERVER_KEY=your_google_server_key

# --- Redis Cache ---
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
SPRING_CACHE_TYPE=simple

# --- Misc ---
SMS_FLAG=false
SHARE_VIDEO_VIEWCOUNT=5
SHARE_VIDEO_REQUESTCOUNT=10
SHARE_VIDEO_EXPIRY_MINUTES=60
FCM_TOPIC=vlearning
SWAGGER_UI_FLAG=true
SWAGGER_API_DOCS_FLAG=true
THREAD_CAR_POOL_SIZE=10
THREAD_MAX_POOL_SIZE=20
THREAD_QUEUE_CAPACITY=100
FIREBASE_REMOTE_CONFIG=dummy
TEST_OTP=123456
VCT_AVAILABLE_DATE=2026-05-30T16:00:00Z
SHOW_VCT_RESULT=false
SPRING_DATASOURCE_INITIALIZATION_MODE=never
APP_DEMO_MODE=false

